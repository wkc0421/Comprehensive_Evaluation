DATABASE_URL="postgresql://postgres:postgres@localhost:5432/guangdong_comprehensive_evaluation"
NODE_ENV="development"

# Object storage placeholders for future source documents and verification materials.
OBJECT_STORAGE_ENDPOINT="http://localhost:9000"
OBJECT_STORAGE_REGION="local"
OBJECT_STORAGE_BUCKET="guangdong-comprehensive-evaluation"
OBJECT_STORAGE_ACCESS_KEY_ID="local-access-key"
OBJECT_STORAGE_SECRET_ACCESS_KEY="local-secret-key"

# Local authentication configuration.
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SESSION_COOKIE_NAME="gce_session"
PHONE_VERIFICATION_REQUEST_URL=""
PHONE_VERIFICATION_VERIFY_URL=""
PHONE_VERIFICATION_API_TOKEN=""
# The local OTP stub is used only when NODE_ENV is development or test.
LOCAL_OTP_ENABLED="true"
LOCAL_OTP_CODE="123456"
